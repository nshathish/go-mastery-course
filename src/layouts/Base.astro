---
import '../styles/prose.css';
interface Props {
  title: string;
  description?: string;
}
const { title, description = "60-day Go mastery schedule" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Go Mastery</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg:       #f9f9f7;
        --surface:  #ffffff;
        --surface2: #f2f2ef;
        --border:   #e0ddd8;
        --border2:  #ebebе8;
        --text:     #1a1a1a;
        --muted:    #6b6b6b;
        --subtle:   #a0a0a0;
        --go-blue:  #007a99;
        --go-dark:  #005f77;
        --purple:   #534ab7;
        --teal:     #0f6e56;
        --coral:    #993c1d;
        --amber:    #854f0b;
        --kw:       #9333ea;
        --ty:       #0369a1;
        --fn:       #c2410c;
        --str:      #15803d;
        --cm:       #a0a0a0;
        --radius:   8px;
        --radius-lg:12px;
        --font:     'Inter', system-ui, sans-serif;
        --mono:     'JetBrains Mono', 'Fira Code', monospace;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: 16px; background: var(--bg); color: var(--text); font-family: var(--font); }
      body { min-height: 100vh; line-height: 1.7; }
      a { color: inherit; text-decoration: none; }
      code, pre { font-family: var(--mono); }
      pre code { font-size: 13px; line-height: 1.8; }
      .kw  { color: var(--kw); font-weight: 500; }
      .ty  { color: var(--ty); }
      .fn  { color: var(--fn); }
      .str { color: var(--str); }
      .cm  { color: var(--cm); font-style: italic; }
    </style>
  </head>
  <body>
    <nav style="border-bottom:1px solid var(--border2);background:var(--surface);position:sticky;top:0;z-index:50;">
      <div style="max-width:1100px;margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;gap:2rem;height:52px;">
        <a href="/" style="display:flex;align-items:center;gap:8px;font-weight:500;font-size:15px;">
          <span style="font-family:var(--mono);color:var(--go-blue);font-size:18px;font-weight:500;">Go</span>
          <span style="color:var(--muted);">mastery</span>
        </a>
        <span style="flex:1"></span>
        <a href="/" style="font-size:13px;color:var(--muted);transition:color .15s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--muted)'">Schedule</a>
      </div>
    </nav>
    <slot />
    <footer style="border-top:1px solid var(--border2);padding:2rem 1.5rem;text-align:center;color:var(--subtle);font-size:13px;margin-top:4rem;">
      60-day Go mastery · <span style="font-family:var(--mono)">1–2 hrs/day</span>
    </footer>
  </body>
</html>
